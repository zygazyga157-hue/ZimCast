{
  "name": "zimcast-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --env-file=.env server.ts",
    "build": "npx prisma generate && npx prisma db push && npx prisma db seed && next build --webpack",
    "start": "cross-env NODE_ENV=production tsx --env-file=.env server.ts",
    "lint": "eslint",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "redis:start": "start /B Redis-8.6.2-Windows-x64-cygwin-with-Service\\redis-server.exe Redis-8.6.2-Windows-x64-cygwin-with-Service\\redis.conf",
    "redis:stop": "Redis-8.6.2-Windows-x64-cygwin-with-Service\\redis-cli.exe shutdown nosave",
    "redis:ping": "Redis-8.6.2-Windows-x64-cygwin-with-Service\\redis-cli.exe ping",
    "postinstall": "npx prisma generate && node scripts/fix-base-ui-types.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --project unit",
    "test:api": "vitest run --project api",
    "test:db": "vitest run --project db"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@types/pg": "8.20.0",
    "@types/video.js": "^7.3.58",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "paynow": "^2.2.2",
    "pg": "8.20.0",
    "prisma": "7.6.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "type-check": "^0.4.0",
    "uuid": "^13.0.0",
    "video.js": "^8.23.7",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "testcontainers": "^11.13.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
