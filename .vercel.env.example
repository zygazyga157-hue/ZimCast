# Copy this file to create a local env reference, but DO NOT commit secrets.
# Example: cp .vercel.env.example .vercel.env.local (add to .gitignore)

# Database
DATABASE_URL=

# Redis
REDIS_URL=

# NextAuth / App secrets
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Stream token HMAC secret
STREAM_TOKEN_SECRET=

# Public stream base URL (HLS origin)
NEXT_PUBLIC_STREAM_BASE_URL=

# S3 / Media storage (if used)
MEDIA_S3_BUCKET=
MEDIA_S3_REGION=
MEDIA_S3_ENDPOINT=
MEDIA_S3_KEY=
MEDIA_S3_SECRET=

# Email / SMTP (for production)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Optional: third-party keys
SENTRY_DSN=

# NOTE: Do NOT commit real secret values to the repo. Add local env files to .gitignore.
