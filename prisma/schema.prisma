generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PaymentProvider {
  ECOCASH
  PAYNOW
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ProgramCategory {
  NEWS
  SPORTS
  ENTERTAINMENT
  MUSIC
  DOCUMENTARY
  GAMING
  TRAVEL
  FOOD
  TECH
  FASHION
  FITNESS
  ART
}

enum ViewAction {
  WATCH
  SKIP
  CLICK
  LIKE
  SEARCH
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String
  name               String?
  phone              String?   @unique
  dateOfBirth        DateTime?
  gender             String?
  city               String?
  country            String?
  avatarKey          String?
  bannerKey          String?
  avatarUrl          String?
  role               Role      @default(USER)
  emailVerified      Boolean   @default(false)
  verifyToken        String?
  verifyTokenExpiry  DateTime?
  resetToken         String?
  resetTokenExpiry   DateTime?
  interests          String[]  @default([])
  language           String    @default("English")
  notificationPrefs  Json?
  lastLoginAt        DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  passes             MatchPass[]
  payments           Payment[]
  viewingActivities  ViewingActivity[]

  @@map("users")
}

model Match {
  id             String   @id @default(cuid())
  homeTeam       String
  awayTeam       String
  kickoff        DateTime
  price          Decimal  @db.Decimal(10, 2)
  streamKey      String   @unique
  isLive         Boolean  @default(false)
  zplsFixtureId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  passes             MatchPass[]
  payments           Payment[]
  programs           Program[]
  viewingActivities  ViewingActivity[]

  @@map("matches")
}

model MatchPass {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@map("match_passes")
}

model Payment {
  id               String          @id @default(cuid())
  userId           String
  matchId          String
  amount           Decimal         @db.Decimal(10, 2)
  provider         PaymentProvider
  status           PaymentStatus   @default(PENDING)
  transactionRef   String?
  pollUrl          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Program {
  id          String          @id @default(cuid())
  channel     String          @default("ZBCTV")
  title       String
  description String?
  category    ProgramCategory @default(ENTERTAINMENT)
  startTime   DateTime
  endTime     DateTime
  isLive      Boolean         @default(false)
  blackout    Boolean         @default(false)
  matchId     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  match             Match?            @relation(fields: [matchId], references: [id], onDelete: SetNull)
  viewingActivities ViewingActivity[]

  @@index([startTime, endTime])
  @@index([channel, startTime])
  @@map("programs")
}

model ProgramTemplate {
  id          String          @id @default(cuid())
  name        String
  channel     String          @default("ZBCTV")
  title       String
  description String?
  category    ProgramCategory @default(ENTERTAINMENT)
  blackout    Boolean         @default(false)
  startHour   Int             // 0-23
  startMinute Int             @default(0)
  durationMin Int             // duration in minutes
  daysOfWeek  Int[]           // 0=Sun, 1=Mon, ... 6=Sat
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("program_templates")
}

model ViewingActivity {
  id            String      @id @default(cuid())
  userId        String
  programId     String?
  matchId       String?
  action        ViewAction  @default(WATCH)
  watchDuration Int         @default(0)
  sessionStart  DateTime    @default(now())
  sessionEnd    DateTime?
  createdAt     DateTime    @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  match   Match?   @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, action])
  @@map("viewing_activities")
}
