generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PaymentProvider {
  ECOCASH
  PAYPAL
  PAYNOW
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  age       Int?
  gender    String?
  city      String?
  country   String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passes   MatchPass[]
  payments Payment[]

  @@map("users")
}

model Match {
  id        String   @id @default(cuid())
  homeTeam  String
  awayTeam  String
  kickoff   DateTime
  price     Decimal  @db.Decimal(10, 2)
  streamKey String   @unique
  isLive    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passes   MatchPass[]
  payments Payment[]

  @@map("matches")
}

model MatchPass {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@map("match_passes")
}

model Payment {
  id               String          @id @default(cuid())
  userId           String
  matchId          String
  amount           Decimal         @db.Decimal(10, 2)
  provider         PaymentProvider
  status           PaymentStatus   @default(PENDING)
  transactionRef   String?
  pollUrl          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("payments")
}
